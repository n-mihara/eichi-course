<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>叡智コース 特設バナー（リンクなし・高視認性大文字版）</title>
    <!-- Google Fonts & FontAwesome -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@1,700;1,800&family=Noto+Sans+JP:wght@900&family=Noto+Serif+JP:ital,wght@0,900;1,900&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        kanto: {
                            purple: '#9a5ebe',     /* 公式HPの気品あるパープル */
                            deepPurple: '#1f0b2a', /* バナー背景をさらに暗く引き締め、文字の視認性を極限まで高める最暗色 */
                            gold: '#D4AF37'        /* 視認性の高い、より明るく輝くゴールド */
                        }
                    },
                    fontFamily: {
                        sans: ['"Noto Sans JP"', 'sans-serif'],
                        serif: ['"Noto Serif JP"', 'serif'],
                        montserrat: ['"Montserrat"', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <style>
        /* ざらっとした高貴な質感を再現しつつ、中央〜下部にかけて明度を落として文字を浮かび上がらせるグラデーション */
        .banner-texture {
            background-color: #9a5ebe;
            background-image: 
                radial-gradient(circle at 15% 20%, rgba(154, 94, 190, 0.98) 0%, rgba(31, 11, 42, 1) 90%),
                url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");
        }

        /* ゴールドの文字盤に圧倒的な輝き、高級感、そして力強い立体陰影を与えるグラデーション */
        .gold-shimmer {
            background: linear-gradient(135deg, #FFFFFF 0%, #F5E5C9 15%, #E5C17D 45%, #C5A059 75%, #FFFFFF 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 4px 10px rgba(0, 0, 0, 0.7));
        }
    </style>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">

    <!-- 570px x 320px 規格サイズバナー (極小サイズに縮小されても読める完全視認性特化仕様) -->
    <div class="relative w-[570px] h-[320px] rounded-xl overflow-hidden shadow-2xl banner-texture flex flex-col justify-between p-7 select-none border border-white/20">
        
        <!-- バナー上部: アピールテキスト（極太・サイズ拡大により読めない問題を完全解決） -->
        <div class="flex justify-between items-start z-10">
            <span class="text-sm md:text-[16px] font-black tracking-widest text-kanto-gold bg-black/40 border-2 border-kanto-gold/60 px-5 py-1.5 rounded-full uppercase shadow-md leading-none">
                最難関国立大学進学へ
            </span>
        </div>

        <!-- バナー中部: メインキャッチコピー (視認性を極限まで高めた超極太・極大文字) -->
        <div class="z-10 my-auto">
            <h2 class="text-white font-sans font-black text-5xl md:text-[58px] leading-tight tracking-wider filter drop-shadow-[0_6px_12px_rgba(0,0,0,0.8)]">
                叡智コース<br>
                誕生。
            </h2>
        </div>

        <!-- バナー下部: 開始年度 (極大フォント・極太斜体でさらに迫力アップ) -->
        <div class="flex justify-between items-end z-10">
            <!-- 2027/4 Start -->
            <div class="font-serif font-black italic text-4xl md:text-[46px] tracking-wider gold-shimmer select-none leading-none">
                2027/4 Start
            </div>
        </div>
    </div>

</body>
</html>
