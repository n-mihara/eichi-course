<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>叡智コース 特設バナー（リンクなし・大文字版）</title>
    <!-- Google Fonts & FontAwesome -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@1,700&family=Noto+Sans+JP:wght@800;900&family=Noto+Serif+JP:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        kanto: {
                            purple: '#9a5ebe',     /* 公式HPの気品あるパープル */
                            deepPurple: '#36164a', /* バナーに深みを出すための最暗色 */
                            gold: '#C5A059'        /* 格調高いゴールド */
                        }
                    },
                    fontFamily: {
                        sans: ['"Noto Sans JP"', 'sans-serif'],
                        serif: ['"Noto Serif JP"', 'serif'],
                        montserrat: ['"Montserrat"', 'sans-serif']
                    }
                }
            }
        }
    </script>
    <style>
        /* ざらっとした質感を再現するための微細なノイズ風テクスチャとグラデーション */
        .banner-texture {
            background-color: #9a5ebe;
            background-image: 
                radial-gradient(circle at 20% 30%, rgba(154, 94, 190, 0.95) 0%, rgba(54, 22, 74, 0.98) 100%),
                url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.04'/%3E%3C/svg%3E");
        }

        /* ゴールド文字にさらなる輝きと高級感を与えるグラデーション */
        .gold-shimmer {
            background: linear-gradient(135deg, #FFF 0%, #D8B475 40%, #C5A059 70%, #F5E5C9 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
        }
    </style>
</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen p-4">

    <!-- 570px x 320px 規格サイズバナー (リンク・ホバーエフェクトなし仕様) -->
    <div class="relative w-[570px] h-[320px] rounded-xl overflow-hidden shadow-2xl banner-texture flex flex-col justify-between p-8 select-none border border-white/10">
        
        <!-- バナー上部: アピールテキスト（文字をさらに大きくクッキリと） -->
        <div class="flex justify-between items-start z-10">
            <span class="text-xs md:text-sm font-black tracking-widest text-kanto-gold bg-white/10 border border-kanto-gold/40 px-4 py-1.5 rounded-full uppercase">
                最難関国立大学進学へ
            </span>
        </div>

        <!-- バナー中部: メインキャッチコピー (視認性を極限まで高めた超大文字) -->
        <div class="z-10 my-auto">
            <h2 class="text-white font-sans font-black text-5xl md:text-[54px] leading-tight tracking-wider filter drop-shadow-[0_5px_10px_rgba(0,0,0,0.6)]">
                叡智コース<br>
                誕生。
            </h2>
        </div>

        <!-- バナー下部: 開始年度 (サイズを極大化し、格式あるフォントに) -->
        <div class="flex justify-between items-end z-10">
            <!-- 2027/4 Start (存在感のあるゴールドグラデーション) -->
            <div class="font-serif font-bold italic text-4xl md:text-[42px] tracking-wider gold-shimmer select-none leading-none">
                2027/4 Start
            </div>
        </div>
    </div>

</body>
</html>
